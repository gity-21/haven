# Haven Sunucu Yapılandırması
# Bu dosyayı .env olarak kopyalayın: cp .env.example .env

# Sunucu portu (varsayılan: 3847)
PORT=3847

# Sunucu adresi (varsayılan: 0.0.0.0)
HOST=0.0.0.0

# FIX #8 — Admin panel token (ZORUNLU — admin panel bu olmadan devre dışı kalır)
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=buraya-guclu-rastgele-bir-token-yazin

# FIX #7 — Sabit Cloudflare tünel domain'iniz varsa buraya ekleyin (opsiyonel)
# Örnek: TUNNEL_ORIGIN=https://benim-sabit-tünelim.trycloudflare.com
# TUNNEL_ORIGIN=

# Veri dizini (varsayılan: proje_koku/data)
# DATA_DIR=/custom/path/to/data
