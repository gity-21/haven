{
    "name": "haven",
    "version": "2.0.0",
    "description": "Private desktop chat application - Premium Discord-like invite-only rooms",
    "homepage": "https://github.com/haven-chat/haven",
    "main": "app/dist/main.js",
    "scripts": {
        "build:server": "tsc -p server/tsconfig.json",
        "build:main": "tsc -p app/tsconfig.main.json",
        "build:renderer": "vite build --config app/renderer/vite.config.ts",
        "build:ts": "npm run build:server && npm run build:main && npm run build:renderer",
        "start": "npm run build:ts && electron .",
        "launch": "electron .",
        "server": "npm run build:server && node server/dist/index.js",
        "dev": "electron . --dev",
        "dev:server": "tsc -p server/tsconfig.json --watch",
        "dev:renderer": "vite --config app/renderer/vite.config.ts",
        "build:win": "npm run build:ts && electron-builder --win",
        "build:setup": "npm run build:ts && electron-builder --win nsis",
        "build:linux": "npm run build:ts && electron-builder --linux",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:verbose": "jest --verbose"
    },
    "build": {
        "appId": "com.haven.app",
        "productName": "Haven",
        "asar": true,
        "directories": {
            "output": "dist"
        },
        "publish": {
            "provider": "github",
            "owner": "haven-chat",
            "repo": "haven"
        },
        "files": [
            "app/dist/**/*",
            "app/renderer/dist/**/*",
            "app/renderer/css/**/*",
            "app/renderer/assets/**/*",
            "server/dist/**/*",
            "assets/**/*",
            "node_modules/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "node_modules/cloudflared/bin/",
                "to": "cloudflared",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "assets/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Haven",
            "installerIcon": "assets/icon.ico",
            "uninstallerIcon": "assets/icon.ico",
            "installerHeaderIcon": "assets/icon.ico",
            "deleteAppDataOnUninstall": false
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "icon": "assets/icon.png",
            "category": "Network"
        }
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cloudflared": "^0.7.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "electron-updater": "^6.8.9",
        "express": "^4.21.2",
        "express-rate-limit": "^8.2.1",
        "multer": "^2.0.2",
        "sanitize-html": "^2.17.1",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "sql.js": "^1.11.0",
        "uuid": "^11.0.5"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/multer": "^1.4.12",
        "@types/node": "^22.10.0",
        "@types/uuid": "^10.0.0",
        "concurrently": "^9.1.2",
        "electron": "^34.5.8",
        "electron-builder": "^25.1.8",
        "jest": "^30.4.2",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.11",
        "typescript": "^5.7.0",
        "vite": "^6.3.0"
    },
    "author": {
        "name": "Haven Team",
        "email": "haven@dcteam.dev"
    },
    "license": "MIT",
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/**/*.test.ts",
            "**/tests/**/*.test.js"
        ],
        "testTimeout": 15000,
        "transform": {
            "^.+\\.ts$": "ts-jest"
        },
        "collectCoverageFrom": [
            "server/src/**/*.ts",
            "app/renderer/src/**/*.ts",
            "!**/node_modules/**"
        ],
        "coverageReporters": [
            "text",
            "lcov"
        ],
        "verbose": true
    }
}
